DATABASE_URL="postgresql://vaultguard:vaultguard@localhost:5438/vaultguard"
PORT=3001
NODE_ENV=development

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.vaultguard.dev
AUTH0_CLIENT_ID=your-platform-client-id

# MediCore Agent (M2M)
MEDICORE_CLIENT_ID=your-medicore-client-id
MEDICORE_CLIENT_SECRET=your-medicore-client-secret

# NatSupply Agent (M2M)
NATSUPPLY_CLIENT_ID=your-natsupply-client-id
NATSUPPLY_CLIENT_SECRET=your-natsupply-client-secret

# VaultGuard
VAULTGUARD_JWT_SECRET=change-this-to-a-random-secret
