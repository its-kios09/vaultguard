DATABASE_URL=postgresql://vaultguard:password@postgres:5432/vaultguard
PORT=3001
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.vaultguard.dev
AUTH0_CLIENT_ID=your-platform-client-id
AUTH0_PLATFORM_CLIENT_SECRET=your-platform-client-secret
MEDICORE_CLIENT_ID=your-medicore-m2m-client-id
MEDICORE_CLIENT_SECRET=your-medicore-m2m-client-secret
NATSUPPLY_CLIENT_ID=your-natsupply-m2m-client-id
NATSUPPLY_CLIENT_SECRET=your-natsupply-m2m-client-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
NODE_ENV=production
